caddyx {
    tls_server_name {$CADDYX_DOMAIN:example.com}

    tuic {
        listen :2443
        users {
            {$TUIC_UUID:FED9B1D2-650F-4024-8FE5-D9D4D432F72F} {$TUIC_PASSWORD:thisisunsafe}
        }

        congestion_control bbr_meta_v1
        auth_timeout 3s
        keepalive_period 10s
        max_udp_relay_packet_size 1350
        bbr_initial_cwnd 512
        initial_packet_size 1350
    }

    trojan {
        listen :2443
        passwords {
            {$TROJAN_PASSWORD:thisisunsafe}
        }
    }

    hysteria2 {
        listen :3443
        auth {
            password {$HYSTERIA2_PASSWORD:thisisunsafe}
        }
        download 200mbps
        upload_limit 100mbps
        keepalive_period 10s
        udp_idle_timeout 60s
        max_idle_timeout 30s
        initial_packet_size 1350
    }

    anytls {
        listen :3443

        password {$ANYTLS_PASSWORD:thisisunsafe}

        brutal {
            enabled true
            download 1gbps
            cwnd_gain 15
        }
    }

    kuic {
        listen :6443
        passwords {
            {$KUIC_PASSWORD:thisisunsafe}
        }

        download 200mbps
        upload_limit 100mbps
        padding initial
        initial_packet_size 1280
        auth_timeout 5s
        keepalive_period 10s
        udp_idle_timeout 60s
        max_idle_timeout 30s
    }

    warp {
        prefer_ip_scan {
            scan_prefixes 162.159.192.0/24
            concurrency 50
            max_rtt 400ms
            scan_timeout 30s
            probe_timeout 180s
            probe_per_target 2s
            failed_ban_window 24h
        }

        mtu 1280
    }
}
